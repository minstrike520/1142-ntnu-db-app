# === 系統配置 ===
NODE_ENV=development

# === 資料庫配置 (PostgreSQL) ===
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpassword
POSTGRES_DB=chatdb
# Prisma 連線字串 (對應上方設定, 預設連接到 docker compose 內部的 DB 容器)
DATABASE_URL=postgresql://chatuser:chatpassword@db:5432/chatdb

# === 後端配置 ===
PORT=4000
JWT_SECRET=dev_secret_key

# === 前端配置 ===
# Frontend 呼叫後端的位址
VITE_API_URL=http://host.example.com:4000
# 前端允許存取的 Host (給 vite allowedHosts 使用)
VITE_ALLOWED_HOST=host.example.com
